# ===== 应用配置 =====
APP_NAME=陆地旅行智能推荐系统
VERSION=3.2.0
PORT=8000
DEBUG=true

# ===== CORS（多个用逗号分隔）=====
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ===== Supabase（稍后配置）=====
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ===== JWT =====
JWT_SECRET=dev-secret-change-me

# ===== 和风天气 =====
QWEATHER_API_KEY=
QWEATHER_BASE=https://devapi.qweather.com

# ===== 高德地图 =====
AMAP_API_KEY=

# ===== DeepSeek =====
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== AI 风控 =====
AI_DAILY_BUDGET=30
AI_GUEST_DAILY_LIMIT=5
AI_USER_DAILY_LIMIT=10
AI_MAX_TOKENS=1024

# ===== 管理员 IP 白名单 =====
ADMIN_IP_WHITELIST=127.0.0.1

# ===== Agent 服务（AI 模块）=====
AGENT_BASE_URL=http://localhost:8001
BACKEND_SERVICE_TOKEN=dev-service-token
