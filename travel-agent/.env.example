# ===== Agent 服务 =====
AGENT_PORT=8001

# ===== DeepSeek =====
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== LLM 调用 =====
LLM_TIMEOUT=30
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# ===== ToolCall =====
MAX_TOOL_ROUNDS=3

# ===== AI 风控 =====
AI_DAILY_BUDGET=30
AI_GUEST_DAILY_LIMIT=5
AI_USER_DAILY_LIMIT=10

# ===== 上下文缓存 =====
CONTEXT_TTL=600
CONTEXT_MAX_MESSAGES=20

# ===== 行程结果缓存 =====
PLAN_CACHE_TTL=3600

# ===== 主项目后端（Agent 反查数据用）=====
BACKEND_BASE_URL=http://localhost:8000
BACKEND_SERVICE_TOKEN=dev-service-token
